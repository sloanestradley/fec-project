# Netlify clean URL rewrites for parameterized profile routes.
# Both Netlify (Pretty URLs enabled) and Cloudflare natively serve simple pages
# like /search, /candidates, /races, /feed at their clean URLs — no rules needed.
#
# Cloudflare overrides these rules with Pages Functions in:
#   functions/candidate/[[catchall]].js
#   functions/committee/[[catchall]].js
# (needed because Cloudflare's Pretty URL layer conflicts with .html rewrite targets)

/candidate/:id    /candidate.html    200
/committee/:id    /committee.html    200
